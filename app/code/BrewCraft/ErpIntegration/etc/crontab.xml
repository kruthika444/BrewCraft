<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">

    <group id="default">

        <job name="brewcraft_product_sync" instance="BrewCraft\ErpIntegration\Cron\ProductSync" method="execute">

            <!-- Every minute (for development/testing) -->
            <schedule>* * * * *</schedule>

        </job>

        <job name="brewcraft_inventory_sync" instance="BrewCraft\ErpIntegration\Cron\InventorySync" method="execute">

            <schedule>* * * * *</schedule>

        </job>

        <job name="brewcraft_price_sync" instance="BrewCraft\ErpIntegration\Cron\PriceSync" method="execute">

            <schedule>* * * * *</schedule>

        </job>
    </group>

</config>
