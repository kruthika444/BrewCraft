<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">

    <system>

        <tab id="brewcraft" translate="label" sortOrder="500">
            <label>BrewCraft</label>
        </tab>

        <section
            id="brewcraft_erp"
            translate="label"
            sortOrder="10"
            showInDefault="1"
            showInWebsite="1"
            showInStore="1">

            <label>ERP Integration</label>

            <tab>brewcraft</tab>

            <resource>BrewCraft_ErpIntegration::config</resource>

            <group
                id="general"
                translate="label"
                sortOrder="10"
                showInDefault="1"
                showInWebsite="1"
                showInStore="1">

                <label>General Settings</label>

                <field
                    id="enabled"
                    translate="label"
                    type="select"
                    sortOrder="10"
                    showInDefault="1"
                    showInWebsite="1"
                    showInStore="1">

                    <label>Enable Integration</label>

                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>

                </field>

                <field
                    id="base_url"
                    translate="label"
                    type="text"
                    sortOrder="20"
                    showInDefault="1"
                    showInWebsite="1"
                    showInStore="1">

                    <label>ERP Base URL</label>

                </field>

                <field
                    id="api_version"
                    translate="label"
                    type="text"
                    sortOrder="30"
                    showInDefault="1"
                    showInWebsite="1"
                    showInStore="1">

                    <label>API Version</label>

                </field>

                <field
                    id="timeout"
                    translate="label"
                    type="text"
                    sortOrder="40"
                    showInDefault="1"
                    showInWebsite="1"
                    showInStore="1">

                    <label>Connection Timeout (Seconds)</label>

                    <validate>validate-number</validate>

                </field>

            </group>

        </section>

    </system>

</config>
