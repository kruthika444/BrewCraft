<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="brewcraft_erp_job" resource="default" engine="innodb" comment="ERP Jobs">

        <column xsi:type="int" name="job_id" identity="true" unsigned="true" nullable="false" comment="Job ID" />

        <column xsi:type="varchar" name="job_type" nullable="false" length="50" />

        <column xsi:type="varchar" name="status" nullable="false" length="20" />

        <column xsi:type="int" name="records_processed" nullable="false" default="0" />

        <column xsi:type="decimal" name="execution_time" precision="12" scale="4" nullable="false" default="0.0000" />

        <column xsi:type="text" name="message" nullable="true" />

        <column xsi:type="timestamp" name="created_at" nullable="false" default="CURRENT_TIMESTAMP" />

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="job_id" />
        </constraint>

    </table>

</schema>
