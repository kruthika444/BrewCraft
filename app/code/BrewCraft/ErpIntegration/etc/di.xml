<?xml version="1.0"?>

<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <type name="BrewCraft\ErpIntegration\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">erpLogger</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">
                    BrewCraft\ErpIntegration\Logger\Handler
                </item>
            </argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="brewcraft_erp_test" xsi:type="object">
                    BrewCraft\ErpIntegration\Console\TestConnection
                </item>
                <item name="inventorySync" xsi:type="object">
                    BrewCraft\ErpIntegration\Console\InventorySync
                </item>
                <item name="priceSync" xsi:type="object">
                    BrewCraft\ErpIntegration\Console\PriceSync
                </item>
                <item name="queueTest" xsi:type="object">
                    BrewCraft\ErpIntegration\Console\QueueTest
                </item>
            </argument>
        </arguments>
    </type>

    <preference for="BrewCraft\ErpIntegration\Api\JobRepositoryInterface" type="BrewCraft\ErpIntegration\Model\JobRepository" />
</config>
