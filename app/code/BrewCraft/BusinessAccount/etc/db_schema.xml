<?xml version="1.0"?>

<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">

    <table name="brewcraft_business_account"
           resource="default"
           engine="innodb"
           comment="BrewCraft Business Account Applications">

        <column xsi:type="int"
                name="entity_id"
                unsigned="true"
                nullable="false"
                identity="true"
                comment="Entity ID"/>

        <column xsi:type="int"
                name="customer_id"
                unsigned="true"
                nullable="false"
                comment="Magento Customer ID"/>

        <column xsi:type="varchar"
                name="company_name"
                nullable="false"
                length="255"
                comment="Company Name"/>

        <column xsi:type="varchar"
                name="registration_number"
                nullable="false"
                length="100"
                comment="Business Registration Number"/>

        <column xsi:type="varchar"
                name="tax_number"
                nullable="true"
                length="100"
                comment="Tax or VAT Number"/>

        <column xsi:type="varchar"
                name="company_type"
                nullable="true"
                length="100"
                comment="Company Type"/>

        <column xsi:type="int"
                name="business_years"
                unsigned="true"
                nullable="true"
                comment="Years in Business"/>

        <column xsi:type="varchar"
                name="contact_name"
                nullable="false"
                length="255"
                comment="Primary Contact Name"/>

        <column xsi:type="varchar"
                name="contact_email"
                nullable="false"
                length="255"
                comment="Primary Contact Email"/>

        <column xsi:type="varchar"
                name="contact_phone"
                nullable="false"
                length="50"
                comment="Primary Contact Phone"/>

        <column xsi:type="text"
                name="street"
                nullable="false"
                comment="Business Street Address"/>

        <column xsi:type="varchar"
                name="city"
                nullable="false"
                length="255"
                comment="City"/>

        <column xsi:type="varchar"
                name="region"
                nullable="true"
                length="255"
                comment="State or Region"/>

        <column xsi:type="varchar"
                name="postcode"
                nullable="false"
                length="20"
                comment="Postcode"/>

        <column xsi:type="varchar"
                name="country_id"
                nullable="false"
                length="2"
                comment="Country Code"/>

        <column xsi:type="varchar"
                name="status"
                nullable="false"
                length="20"
                default="pending"
                comment="Application Status"/>

        <column xsi:type="text"
                name="admin_comment"
                nullable="true"
                comment="Admin Approval or Rejection Comment"/>

        <column xsi:type="timestamp"
                name="approved_at"
                nullable="true"
                on_update="false"
                comment="Approval Date and Time"/>

        <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="false"
                comment="Created At"/>

        <column xsi:type="timestamp"
                name="updated_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary"
                    referenceId="PRIMARY">

            <column name="entity_id"/>

        </constraint>

        <constraint xsi:type="foreign"
                    referenceId="BREWCRAFT_BUSINESS_ACCOUNT_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="brewcraft_business_account"
                    column="customer_id"
                    referenceTable="customer_entity"
                    referenceColumn="entity_id"
                    onDelete="CASCADE"/>

        <constraint xsi:type="unique"
                    referenceId="BREWCRAFT_BUSINESS_ACCOUNT_CUSTOMER_ID_UNIQUE">

            <column name="customer_id"/>

        </constraint>

        <constraint xsi:type="unique"
                    referenceId="BREWCRAFT_BUSINESS_ACCOUNT_REGISTRATION_NUMBER_UNIQUE">

            <column name="registration_number"/>

        </constraint>

        <index referenceId="BREWCRAFT_BUSINESS_ACCOUNT_STATUS"
               indexType="btree">

            <column name="status"/>

        </index>

        <index referenceId="BREWCRAFT_BUSINESS_ACCOUNT_CREATED_AT"
               indexType="btree">

            <column name="created_at"/>

        </index>

    </table>

</schema>
